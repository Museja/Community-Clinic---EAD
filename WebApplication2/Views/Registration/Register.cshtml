@model WebApplication2.Models.Registration

<form method="post">

    <label>Full Name</label>
    <input type="text" name="FullName" />

    <label>Email</label>
    <input type="email" name="EmailAddress" />

    <label>Password</label>
    <input type="password" name="Password" />

    <label>Confirm Password</label>
    <input type="password" name="ConfirmPassword" />

    <br /><br />

    <!-- Role Selection -->
    <label><input type="radio" name="Role" value="Patient" onclick="toggleFields()" /> Patient</label>
    <label><input type="radio" name="Role" value="Admin" onclick="toggleFields()" /> Admin</label>
    <label><input type="radio" name="Role" value="MedicalStaff" onclick="toggleFields()" /> Medical Staff</label>

    <br /><br />

    <!-- Admin ID -->
    <div id="adminField" style="display:none;">
        <label>Admin ID</label>
        <input type="text" name="AdminId" />
    </div>

    <!-- Medical Staff ID -->
    <div id="medicalField" style="display:none;">
        <label>Medical Staff ID</label>
        <input type="text" name="MedicalStaffId" />
    </div>

    <br />

    <button type="submit">Register</button>

</form>

<script>
    function toggleFields() {
        var role = document.querySelector('input[name="Role"]:checked')?.value;

        document.getElementById("adminField").style.display =
            role === "Admin" ? "block" : "none";

        document.getElementById("medicalField").style.display =
            role === "MedicalStaff" ? "block" : "none";
    }
</script>